# ── API Keys (required) ──────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Database (SQLite — no expiry, no external service) ───────────────────────
# FIX #3: Using SQLite instead of PostgreSQL (no 30-day expiry like Render Postgres)
DATABASE_URL=sqlite+aiosqlite:///./data/technova.db

# ── Redis (required for session state & conversation memory) ─────────────────
REDIS_URL=redis://localhost:6379

# ── Security ─────────────────────────────────────────────────────────────────
# FIX #6: Do NOT use CORS_ORIGINS=* — set to your exact deployed URL
# Development:
CORS_ORIGINS=["http://localhost:8000"]
# Production (uncomment and set your Render URL):
# CORS_ORIGINS=["https://technova-voice-bot.onrender.com"]

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
VERSION=1.0.0

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_TTL_SECONDS=1800
# FIX #9: Lock TTL extended to 30s (was 10s — too short for LLM responses)
LOCK_TTL_SECONDS=30

# ── Rate Limiting (FIX #8) ────────────────────────────────────────────────────
MAX_CONCURRENT_WS_PER_IP=5

# ── Audio Pipeline (FIX #7, #14) ─────────────────────────────────────────────
# Flush sentence buffer after this many ms even without sentence terminator
SENTENCE_FLUSH_TIMEOUT_MS=500

# ── VAD (FIX #2) ─────────────────────────────────────────────────────────────
# Path to Silero VAD ONNX model (auto-downloaded on first run if missing)
# SILERO_VAD_PATH=/app/data/silero_vad.onnx
